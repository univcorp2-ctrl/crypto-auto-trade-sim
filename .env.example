# Market data / daily report
EXCHANGE_PROFILE=binance-spot
EXCHANGE_REST_BASE=https://api.binance.com
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
REPORT_TIME_ZONE=Asia/Tokyo

# Optional Slack or Discord incoming webhook for daily report notifications.
# Store this as a GitHub Actions secret named DAILY_REPORT_WEBHOOK_URL.
DAILY_REPORT_WEBHOOK_URL=

# Execution defaults. Keep these safe until paper trading is complete.
EXECUTION_PROFILE=binance-spot-testnet
TRADING_DRY_RUN=true
ENABLE_LIVE_TRADING=false
MAX_ORDER_USD=25
MAX_POSITION_USD=100
MAX_DAILY_LOSS_PCT=0.02
MAX_CONSECUTIVE_LOSSES=3
MAX_API_FAILURES=5

# Never commit real API keys. Use GitHub Actions secrets or a server-side secret manager.
BINANCE_API_KEY=
BINANCE_API_SECRET=
